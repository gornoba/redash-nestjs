{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:api && npm run build:worker && npm run build:alert && npm run build:schedule",
    "build:alert": "nest build alert",
    "build:api": "nest build api",
    "build:schedule": "nest build schedule",
    "build:worker": "nest build worker",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "typeorm": "typeorm-ts-node-commonjs -d ./libs/database/src/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create ./libs/database/src/migrations/$npm_config_name",
    "migration:generate": "typeorm-ts-node-commonjs -d ./libs/database/src/data-source.ts migration:generate ./libs/database/src/migrations/$npm_config_name",
    "migration:run": "typeorm-ts-node-commonjs -d ./libs/database/src/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d ./libs/database/src/data-source.ts migration:revert",
    "script:migrate-data-source-options:legacy": "node -r ts-node/register -r tsconfig-paths/register ./scripts/migrate-data-source-options-to-legacy.ts",
    "script:reset-user-passwords": "node -r ts-node/register -r tsconfig-paths/register ./scripts/reset-user-passwords-to-default.ts",
    "start": "nest start api",
    "start:api": "nest start api",
    "start:api:dev": "nest start api --watch",
    "start:alert": "nest start alert",
    "start:alert:dev": "nest start alert --watch",
    "start:alert:prod": "node dist/apps/alert/main",
    "start:debug": "nest start api --debug --watch",
    "start:prod": "node dist/apps/api/main",
    "start:schedule": "nest start schedule",
    "start:schedule:dev": "nest start schedule --watch",
    "start:schedule:prod": "node dist/apps/schedule/main",
    "start:worker": "nest start worker",
    "start:worker:dev": "nest start worker --watch",
    "start:worker:prod": "node dist/apps/worker/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api/test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "fernet": "^0.3.3",
    "mssql": "^12.2.0",
    "mysql2": "^3.19.1",
    "nestjs-zod": "^5.1.1",
    "nodemailer": "^8.0.2",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sha512crypt-node": "^1.0.2",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/crypto-js": "^4.2.2",
    "@types/fernet": "^0.4.3",
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^5.1.2",
    "@types/mssql": "^9.1.9",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "swc-loader": "^0.2.7",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@app/common$": "<rootDir>/libs/common/src",
      "^@app/common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/database$": "<rootDir>/libs/database/src",
      "^@app/database/(.*)$": "<rootDir>/libs/database/src/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
